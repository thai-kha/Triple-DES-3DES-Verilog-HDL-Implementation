initial 

begin 
$timeformat(-12,3," ps",6);
#3000000;
if (nummismatches > 0)
	$display ("%d mismatched vectors : Simulation failed !",nummismatches);
else
	$display ("Simulation passed !");
$finish;
end 
endmodule

module des3_top_vlg_vec_tst();
// constants                                           
// general purpose registers
reg clock;
reg [63:0] key0;
reg [63:0] key1;
reg [63:0] key2;
reg [63:0] plaintext_in;
reg rst;
reg start;
// wires                                               
wire [63:0] ciphertext_out;
wire done_all;
wire [63:0] recovered_out;

wire sampler;                             

// assign statements (if any)                          
des3_top i1 (
// port map - connection between master ports and signals/registers   
	.ciphertext_out(ciphertext_out),
	.clock(clock),
	.done_all(done_all),
	.key0(key0),
	.key1(key1),
	.key2(key2),
	.plaintext_in(plaintext_in),
	.recovered_out(recovered_out),
	.rst(rst),
	.start(start)
);

// clock
initial
begin
	clock = 1'b1;
	# 10000;
	repeat(149)
	begin
		clock = 1'b0;
		clock = #10000 1'b1;
		# 10000;
	end
	clock = 1'b0;
end 
// key0[ 63 ]
initial
begin
	key0[63] = 1'b1;
end 
// key0[ 62 ]
initial
begin
	key0[62] = 1'b0;
end 
// key0[ 61 ]
initial
begin
	key0[61] = 1'b1;
end 
// key0[ 60 ]
initial
begin
	key0[60] = 1'b0;
end 
// key0[ 59 ]
initial
begin
	key0[59] = 1'b1;
end 
// key0[ 58 ]
initial
begin
	key0[58] = 1'b0;
end 
// key0[ 57 ]
initial
begin
	key0[57] = 1'b1;
end 
// key0[ 56 ]
initial
begin
	key0[56] = 1'b1;
end 
// key0[ 55 ]
initial
begin
	key0[55] = 1'b1;
end 
// key0[ 54 ]
initial
begin
	key0[54] = 1'b1;
end 
// key0[ 53 ]
initial
begin
	key0[53] = 1'b0;
end 
// key0[ 52 ]
initial
begin
	key0[52] = 1'b0;
end 
// key0[ 51 ]
initial
begin
	key0[51] = 1'b1;
end 
// key0[ 50 ]
